DEEPSEEK_API_KEY=sk-

# Prospecção de imobiliárias (comando `prospecting find`). Chave da
# Google Places API (v1) para descobrir imobiliárias por cidade.
GOOGLE_PLACES_API_KEY=

# Postgres sink (opcional). Se todas as variáveis estiverem preenchidas,
# o crawler persistirá os resultados no banco em vez de apenas JSON.
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
