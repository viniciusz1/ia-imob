{
  "framework": null,
  "buildCommand": "",
  "installCommand": "",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "build": {
    "env": {
      "COMPOSER_PROCESS_TIMEOUT": "600",
      "COMPOSER_NO_INTERACTION": "1"
    }
  }
}
